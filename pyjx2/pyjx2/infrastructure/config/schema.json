{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pyjx2 Configuration",
  "description": "Configuration schema for pyjx2 — Jira/Xray automation tool",
  "type": "object",
  "properties": {
    "jira": {
      "type": "object",
      "description": "Jira connection settings",
      "properties": {
        "env": {
          "type": "string",
          "description": "Environment to connect to: QA or DEV",
          "enum": ["QA", "DEV"]
        },
        "username": {
          "type": "string",
          "description": "Jira username or email"
        },
        "password": {
          "type": "string",
          "description": "Jira password or API token"
        }
      },
      "required": ["username", "password"]
    },
    "xray": {
      "type": "object",
      "description": "Xray connection settings",
      "properties": {
        "client_id": {
          "type": "string",
          "description": "Xray Cloud client ID"
        },
        "client_secret": {
          "type": "string",
          "description": "Xray Cloud client secret"
        },
        "base_url": {
          "type": "string",
          "description": "Xray API base URL (default: https://xray.cloud.getxray.app/api/v2)"
        }
      }
    },
    "setup": {
      "type": "object",
      "description": "Valores por defecto para el comando setup",
      "properties": {
        "test_plan_key": {
          "type": "string",
          "description": "Llave del Test Plan origen (ej. QAX-100)"
        },
        "execution_summary": {
          "type": "string",
          "description": "Título del nuevo Test Execution"
        },
        "test_mode": {
          "type": "string",
          "description": "Modo de tests: 'clone' (copiar en QAX) o 'add' (agregar sin clonar)",
          "enum": ["clone", "add"],
          "default": "clone"
        }
      }
    },
    "sync": {
      "type": "object",
      "description": "Default values for the sync command",
      "properties": {
        "execution_key": {
          "type": "string"
        },
        "folder": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "TODO", "EXECUTING", "ABORTED"]
        },
        "recursive": {
          "type": "boolean",
          "default": true
        },
        "upload_mode": {
          "type": "string",
          "enum": ["append", "replace"],
          "default": "append"
        },
        "allowed_extensions": {
          "type": "array",
          "items": { "type": "string" },
          "default": [".pdf"]
        }
      }
    }
  },
  "required": ["jira"]
}
