## 4. Diagrama de Paquetes (Estructura del Proyecto)

```plantuml
@startuml
package "pyjx2" {
    package "api" {
        [client.py (Facade)]
    }
    
    package "cli" {
        [app.py (Typer)]
    }
    
    package "tui" {
        [app.py (Textual)]
    }

    package "application" {
        package "use_cases" {
            [setup_interactor]
        }
        package "services" {
            [sync_service]
            [encryption_service]
        }
    }

    package "domain" {
        package "entities" {
            [Test / TestSet / TestExecution]
        }
        package "repositories" {
            [Interfaces]
        }
    }

    package "infrastructure" {
        package "jira / xray" {
            [REST Clients]
            [Imp. Repositorios]
        }
        [config (Settings)]
    }
}

api ..> application
cli ..> api
tui ..> api
application ..> domain
infrastructure ..> domain
@enduml
```

