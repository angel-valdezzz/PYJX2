# pyjx2.toml — Configuration file for pyjx2
# Copy this file to pyjx2.toml (or pyjx2.json) in your working directory.
# All values can also be set via environment variables:
#   PYJX2_JIRA_URL, PYJX2_JIRA_USERNAME, PYJX2_JIRA_API_TOKEN
#   PYJX2_XRAY_CLIENT_ID, PYJX2_XRAY_CLIENT_SECRET

[jira]
url = "https://yourorg.atlassian.net"
username = "user@example.com"
api_token = "YOUR_JIRA_API_TOKEN"
project_key = "PROJ"             # Optional default project key

[xray]
client_id = "YOUR_XRAY_CLIENT_ID"
client_secret = "YOUR_XRAY_CLIENT_SECRET"
# base_url = "https://xray.cloud.getxray.app/api/v2"  # default, usually no need to change

[setup]
# Default values for the `pyjx2 setup` command (all overridable via CLI args)
project_key = "PROJ"
test_plan_key = "PROJ-100"
execution_summary = "Sprint 1 Execution"
test_set_summary = "Sprint 1 Test Set"
reuse_tests = false

[sync]
# Default values for the `pyjx2 sync` command (all overridable via CLI args)
execution_key = "PROJ-200"
folder = "./evidence"
status = "PASS"
recursive = true
