{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pyjx2 Configuration",
  "description": "Configuration schema for pyjx2 — Jira/Xray automation tool",
  "type": "object",
  "properties": {
    "auth": {
      "type": "object",
      "description": "Authentication settings for the Atlassian platform",
      "properties": {
        "env": {
          "type": "string",
          "description": "Deployment target to connect to: QA or DEV",
          "enum": ["QA", "DEV"]
        },
        "username": {
          "type": "string",
          "description": "Jira username or email"
        },
        "password": {
          "type": "string",
          "description": "Jira password or API token"
        }
      },
      "required": ["username", "password"]
    },
    "project": {
      "type": "object",
      "description": "Project defaults shared by setup flows",
      "properties": {
        "key": {
          "type": "string",
          "description": "Default project key for created issues (ej. PROJ)"
        }
      }
    },
    "setup": {
      "type": "object",
      "description": "Valores por defecto para el comando setup",
      "properties": {
        "test_plan_key": {
          "type": "string",
          "description": "Llave del Test Plan origen (ej. QAX-100)"
        },
        "execution_summary": {
          "type": "string",
          "description": "Título del nuevo Test Execution"
        },
        "test_mode": {
          "type": "string",
          "description": "Modo de tests: 'clone' (copiar en QAX) o 'add' (agregar sin clonar)",
          "enum": ["clone", "add"],
          "default": "clone"
        }
      }
    },
    "sync": {
      "type": "object",
      "description": "Default values for the sync command",
      "properties": {
        "execution_key": {
          "type": "string"
        },
        "folder": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "TODO", "EXECUTING", "ABORTED"]
        },
        "recursive": {
          "type": "boolean",
          "default": true
        },
        "upload_mode": {
          "type": "string",
          "enum": ["append", "replace"],
          "default": "append"
        },
        "allowed_extensions": {
          "type": "array",
          "items": { "type": "string" },
          "default": [".pdf"]
        }
      }
    }
  },
  "required": ["auth"]
}
